# Protocollo: imap oppure pop3
MAIL_PROTOCOL=imap

# Server posta
MAIL_HOST=imap.example.com
MAIL_PORT=993
MAIL_SSL=true

# Credenziali
MAIL_USER=user@example.com
MAIL_PASSWORD=change-me

# Solo per IMAP
IMAP_MAILBOX=INBOX

# Web server
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Ogni quanti secondi controllare la mailbox
POLL_INTERVAL=300

# Giorni di permanenza degli IP.
# 0 = mantieni per sempre.
RETENTION_DAYS=60

# Livello log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO